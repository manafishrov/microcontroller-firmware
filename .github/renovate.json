{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices",
    ":separateMultipleMajorReleases",
    "abandonments:recommended",
    ":maintainLockFilesWeekly",
    ":semanticCommits",
    ":dependencyDashboard"
  ],
  "timezone": "Europe/Oslo",
  "schedule": ["before 09:00 on monday"],
  "prConcurrentLimit": 10,
  "prHourlyLimit": 10,
  "labels": ["dependencies"],
  "commitMessagePrefix": "chore(deps): ",
  "osvVulnerabilityAlerts": true,
  "vulnerabilityAlerts": {
    "labels": ["dependencies", "security"]
  },
  "enabledManagers": ["nix", "github-actions", "custom.regex"],
  "nix": {
    "enabled": true
  },
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": ["before 09:00 on monday"]
  },
  "packageRules": [
    {
      "matchUpdateTypes": ["digest", "pinDigest"],
      "groupName": "container & action digests",
      "automerge": true,
      "platformAutomerge": true
    },
    {
      "matchUpdateTypes": ["patch"],
      "groupName": "all patch dependencies",
      "automerge": true,
      "platformAutomerge": true
    },
    {
      "matchUpdateTypes": ["minor"],
      "groupName": "all minor dependencies"
    },
    {
      "matchUpdateTypes": ["lockFileMaintenance"],
      "groupName": "lock file maintenance",
      "automerge": true,
      "platformAutomerge": true
    },
    {
      "matchManagers": ["github-actions"],
      "groupName": "github actions",
      "automerge": true,
      "platformAutomerge": true
    },
    {
      "matchManagers": ["nix"],
      "groupName": "nix flake updates",
      "automerge": true,
      "platformAutomerge": true
    }
  ],
  "customManagers": [
    {
      "description": "Pico SDK version pinned via CMake fetch",
      "customType": "regex",
      "managerFilePatterns": ["/CMakeLists\\.txt$/", "/pico_sdk_import\\.cmake$/"],
      "matchStrings": [
        "#\\s*renovate:\\s*depName=(?<depName>\\S+)\\s+set\\([^)]*VERSION\\s+(?<currentValue>v?[0-9.]+)\\)"
      ],
      "datasourceTemplate": "github-releases"
    }
  ]
}
